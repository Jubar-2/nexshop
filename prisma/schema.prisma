// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- User & Authentication ---
model User {
  id           String     @id @default(cuid())
  fullName     String
  email        String     @unique
  phoneNumber  String     @unique
  password     String
  refreshToken String?
  role         Role       @default(FREELANCER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())

  // Relations
  freelancer Freelancer?
  address    Address?
  jobsPosted Jobs[]
}

enum Role {
  ADMIN
  FREELANCER
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum JobStatus {
  ACTIVE
  INACTIVE
}

// --- Freelancer Profile & Performance ---
model Freelancer {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id])
  referKey       String?        @unique
  memberPlanId   String
  membershipPlan MembershipPlan @relation(fields: [memberPlanId], references: [id])

  // Statistics for Logic
  totalSuccessRate Float @default(0) // Overall Success %
  currentBalance   Float @default(0)
  totalApprove     Int   @default(0)
  totalReject      Int   @default(0)
  totalSubmit      Int   @default(0)

  // Relations
  skills Skill[]
}

model MembershipPlan {
  id              String        @id @default(cuid())
  membershipName  String        @unique
  jobsSubmitLimit Int
  description     String?       @db.VarChar(100)
  planOrder       Int           @unique // 1 for Diamond, 2 for Gold, etc.
  isDefault       Boolean       @default(false)
  offers          MemberOffer[]
  freelancers     Freelancer[]
}

model MemberOffer {
  id               String @id @default(cuid())
  membershipPlanId String
  offerId          String

  offer          Offers         @relation(fields: [offerId], references: [id])
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id])
}

model Offers {
  id          String        @id @default(cuid())
  offerTitle  String
  memberOffer MemberOffer[]
}

model Skill {
  id            String      @id @default(cuid())
  freelancerId  String
  freelancer    Freelancer  @relation(fields: [freelancerId], references: [id])
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  subCategoryId String
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])

  successRate Float @default(0) // Specific Sub-category Success %

  @@unique([freelancerId, subCategoryId])
}

// --- Jobs & Categories ---
model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  subCategories SubCategory[]
  jobs          Jobs[]
  skills        Skill[]
}

model SubCategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  jobs       Jobs[]
  skills     Skill[]
}

model Jobs {
  id String @id @default(cuid())

  userId String // Admin who posted the job

  // Job Details
  jobTitle      String
  targetLink    String    @db.VarChar(100)
  description   String    @db.Text
  totalSlots    Int // How many freelancers can do this
  categoryId    String
  subCategoryId String
  reward        Float // price per job
  status        JobStatus @default(ACTIVE)

  // Relations
  category    Category    @relation(fields: [categoryId], references: [id])
  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])
  postedBy    User        @relation(fields: [userId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
}

// --- Location & Address ---
model Country {
  id          String     @id @default(cuid())
  countryName String     @unique
  divisions   Division[]
  addresses   Address[]
}

model Division {
  id           String     @id @default(cuid())
  divisionName String
  countryId    String
  country      Country    @relation(fields: [countryId], references: [id])
  districts    District[]
  addresses    Address[]
}

model District {
  id           String        @id @default(cuid())
  districtName String
  divisionId   String
  division     Division      @relation(fields: [divisionId], references: [id])
  subDistricts SubDistrict[]
  addresses    Address[]
}

model SubDistrict {
  id              String    @id @default(cuid())
  subDistrictName String
  districtId      String
  district        District  @relation(fields: [districtId], references: [id])
  addresses       Address[]
}

model Address {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  countryId     String
  country       Country     @relation(fields: [countryId], references: [id])
  divisionId    String
  division      Division    @relation(fields: [divisionId], references: [id])
  districtId    String
  district      District    @relation(fields: [districtId], references: [id])
  subDistrictId String
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])
  postalCode    Int
}
